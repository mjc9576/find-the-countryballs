  <Item class="ScriptService">
    <Properties>
      <string name="Name">ScriptService</string>
    </Properties>
    <Item class="ScriptInstance">
      <Properties>
        <string name="Source">local environment = game["Environment"]
local players = game["Players"]
local environmentBallsFolder = environment["Balls"] ---@cast environmentBallsFolder Folder

players.PlayerAdded:Connect(function (player)

    local leaderstats = Instance.New("Folder", player) ---@cast leaderstats Instance
    leaderstats.Name = "Leaderstats"

    local ballsFolder = Instance.New("Folder", player)
    ballsFolder.Name = "Balls"

    local ballsFound = Instance.New("IntValue", leaderstats)
    ---@cast ballsFound IntValue
    ballsFound.Name = "BallsFound"
    ballsFound.Value = 0


    -- idk bro, this is what the tutorial did
    local balls = {}
    for i, v in pairs(environmentBallsFolder:GetChildren()) do
        table.insert(balls, v.Name)
    end

    for i, v in pairs(balls) do
        local newBall = Instance.New("BoolValue", ballsFolder) ---@cast newBall BoolValue
        newBall.Name = balls[i]
        newBall.Value = false
    end


end)</string>
        <string name="Name">LeaderStats</string>
      </Properties>
    </Item>
  </Item>
